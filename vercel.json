{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key"
  },
  "functions": {
    "pages/api/news.js": { "maxDuration": 30 },
    "pages/api/market-data.js": { "maxDuration": 15 },
    "pages/api/alert.js": { "maxDuration": 20 }
  },
  "crons": [
    {
      "path": "/api/alert",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/alert",
      "schedule": "0 */2 * * *"
    }
  ]
}
