# ════════════════════════════════════════════════════
# GEWI — Global Eco-War Impact Index
# Copy this to .env.local and fill in your values
# ════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────
# Gemini Flash API key
# Get FREE at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, no credit card needed
GEMINI_API_KEY=AIza-your-gemini-key-here

# ── OPTIONAL: Site URL ───────────────────────────────
NEXT_PUBLIC_SITE_URL=https://gewi.live

# ── EMAIL CAPTURE (pick ONE provider) ────────────────

# Beehiiv — best for newsletters + paid subscriptions
# https://app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=your-beehiiv-api-key
BEEHIIV_PUB_ID=your-publication-id

# Mailchimp — free up to 500 contacts
# https://mailchimp.com → Account → Extras → API Keys
MAILCHIMP_API_KEY=your-mailchimp-api-key-us1
MAILCHIMP_LIST_ID=your-audience-list-id

# ConvertKit
CONVERTKIT_API_KEY=your-convertkit-api-key
CONVERTKIT_FORM_ID=your-form-id

# ── X / TWITTER AUTO-POSTING ─────────────────────────
# developer.twitter.com → App → Keys and Tokens
# Requires Basic plan ($100/mo) for write access
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ── CRON SECURITY ────────────────────────────────────
CRON_SECRET=any-random-string-you-choose
